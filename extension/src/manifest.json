{
  "manifest_version": 3,
  "name": "AgentX",
  "description": "Autonomous LinkedIn Networking",
  "version": "1.1.1",
  "action": {
    "default_popup": "src/popup.html"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://*.linkedin.com/*", "http://localhost:4000/*"],
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*", "http://localhost:3000/*"],
      "js": ["src/content.ts"]
    }
  ],
  "background": {
    "service_worker": "src/background.ts"
  }
}
